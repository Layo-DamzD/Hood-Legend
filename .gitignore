# Godot 4+ specific ignores
.godot/
/android/build/

# Godot script UIDs (auto-generated, different per machine)
*.uid

# Godot import files (auto-generated by editor)
*.import

# Mono / C# build artifacts (if you ever use C#)
.mono/
data_*/
mono_crash.*.json

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# Editor-specific
*.swp
*.swo
*~

# Don't track export builds
*.exe
*.apk
*.aab
*.app
*.dmg
*.deb
*.rpm
*.x86_64

# Logs and temp files
*.log
*.tmp
